<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title><%= title%></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="header1">
      <h1>Wellspring College Staff Movement Admin Dashboard</h1>
    </div>
    <div class="creatediv">
      <div class="abdiv">
        <ul>
           <% if(staffuser){%>
          <li>
            <a href="/createmovement"><button>CREATE</button></a>
          </li>
          <li>
            <a href="/about"><button>ABOUT</button></a>
          </li>
        </ul>
      </div>
     <div class="navdiv">
        <ul>
           <li>Welcome,<%=staffuser.email%></li>
            <li>
            <a href="/logout"><button>LOGOUT</button></a>
          </li>
          <%}else{%>
               <li>
            <a href="/login"><button>LOG IN</button></a>
          </li>
          <li>
            <a href="/signup"><button>SIGN UP</button></a>
          </li>
       <%}%> 
        </ul>
      </div>
    </div>
    </div>
    <h2 class="staffdiv">Staff Movement Notifications</h2>
    <div class="stafflogdiv">
     <% notifications.forEach(notification => { %>

        <p><%= notification.message %></p>
        <p><%= notification.createdAt %></p>

<% }) %>
    </div>
  </body>
</html>
