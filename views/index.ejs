           <li>
            <a href="/createmovement"><button>CREATE</button></a>
          </li>
          <li>
            <a href="/about"><button>ABOUT</button></a>
          </li>
           <li>Welcome, <%= staffuser.email %></li>
            <li>
            <a href="/logout"><button>LOGOUT</button></a>
          </li>
          <%}else{%>
           <li>
            <a href="/login"><button>LOG IN</button></a>
          </li>
          <li>
            <a href="/signup"><button>SIGN UP</button></a>
          </li>
         <%}%> 
        </ul>
      </div>
    </div>
  </div>
    <a href="/staff" class="butdiv"><button>View Movement Log</button></a>
  </body>
</html>
