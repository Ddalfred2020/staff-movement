<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title><%= title%></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="header1">
      <h1>Wellspring College Staff Movement</h1>
    </div>
    <div class="creatediv">
      <div class="abdiv">
        <ul>
          <li>
            <a href="/createmovement"><button>CREATE</button></a>
          </li>
          <li>
            <a href="/about"><button>ABOUT</button></a>
          </li>
        </ul>
      </div>
      <div class="navdiv">
        <ul>
          <li>
            <a href="/login"><button>LOGIN</button></a>
          </li>
          <li>
            <a href=""><button>LOGOUT</button></a>
          </li>
          <li>
            <a href="/signup"><button>SIGN UP</button></a>
          </li>
        </ul>
      </div>
    </div>
    <h2 class="staffdiv">Staff Movement Log</h2>
    <div class="stafflogdiv">
      <% if(result.length>1){%>
       <% result.forEach((items)=>{%>
      <p><%= items.staffname%></p>
      <p><%= items.destination%></p>
      <p><%= items.purpose%></p>
      <p><%= items.department%></p>
      <p><%= items.authorization%></p>
      <p><%= items.possiblereturn%></p>
      <p><%= items.timeout%></p>
      <p><%= items.timein%></p>
       <p><%= items.createdAt%></p>
       <p><%= items.updatedAt%></p>
      <% })%>
      <%}else{%>
       <P>There is no staff movement log to display for now</P>
       <% }%>
    </div>
  </body>
</html>
